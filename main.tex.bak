\appendix
\chapter{APPENDIX}\label{appendix}

\section{PostgreSQL Relational Table
Schema}\label{postgresql-relational-table-schema}

\begin{quote}
\emph{-\/- Users table for authentication and roles} \textbf{CREATE
TABLE} users
(\includegraphics[width=6.36181in,height=7.67778in]{./media/image49.png}

id SERIAL \textbf{PRIMARY KEY},

name \textbf{VARCHAR}(255) \textbf{NOT NULL},

email \textbf{VARCHAR}(255) \textbf{UNIQUE NOT NULL},

password\_hash \textbf{VARCHAR}(255) \textbf{NOT NULL},

\textbf{role VARCHAR}(50) \textbf{NOT NULL CHECK} (\textbf{role IN}
('Staff', 'Manager')), created\_at \textbf{TIMESTAMP DEFAULT
CURRENT\_TIMESTAMP}

);

\emph{-\/- Medicines inventory tracking table} \textbf{CREATE TABLE}
medicines\_inventory (

id SERIAL \textbf{PRIMARY KEY},

trade\_name \textbf{VARCHAR}(255) \textbf{UNIQUE NOT NULL},

active\_substance \textbf{VARCHAR}(255) \textbf{NOT NULL},
normalized\_name \textbf{VARCHAR}(255) \textbf{NOT NULL},

stock\_count \textbf{INT NOT NULL DEFAULT} 0 \textbf{CHECK}
(stock\_count \textgreater= 0), cost \textbf{DECIMAL}(10, 2) \textbf{NOT
NULL CHECK} (cost \textgreater= 0),

price \textbf{DECIMAL}(10, 2) \textbf{NOT NULL CHECK} (price
\textgreater= 0),

expiry\_date \textbf{DATE NOT NULL}, dosage\_form \textbf{VARCHAR}(100)
\textbf{NOT NULL}, manufacturer \textbf{VARCHAR}(255) \textbf{NOT NULL},

created\_at \textbf{TIMESTAMP DEFAULT CURRENT\_TIMESTAMP}

);

\emph{-\/- Indexing for normalized name fuzzy searches}

\textbf{CREATE INDEX} idx\_medicines\_normalized \textbf{ON}
medicines\_inventory(normalized\_name);

\emph{-\/- Prescriptions tracking table} \textbf{CREATE TABLE}
prescriptions (

id SERIAL \textbf{PRIMARY KEY},

patient\_name \textbf{VARCHAR}(255) \textbf{NOT NULL},

status \textbf{VARCHAR}(50) \textbf{NOT NULL CHECK} (status \textbf{IN}
('Pending', 'Processing', ' Dispensed', 'Ready')),

created\_at \textbf{TIMESTAMP DEFAULT CURRENT\_TIMESTAMP}

);

\emph{-\/- Prescription item lookup table} \textbf{CREATE TABLE}
prescription\_items (

id SERIAL \textbf{PRIMARY KEY},

prescription\_id \textbf{INT} REFERENCES prescriptions(id) \textbf{ON
DELETE CASCADE}, medicine\_id \textbf{INT} REFERENCES
medicines\_inventory(id) \textbf{ON DELETE RESTRICT}, quantity
\textbf{INT NOT NULL CHECK} (quantity \textgreater{} 0)

);

\emph{-\/- Supplier invoices tracking table} \textbf{CREATE TABLE}
invoices\_fawateer (

id SERIAL \textbf{PRIMARY KEY},

supplier\_name \textbf{VARCHAR}(255) \textbf{NOT NULL},

total\_amount \textbf{DECIMAL}(10, 2) \textbf{NOT NULL CHECK}
(total\_amount \textgreater= 0), created\_at \textbf{TIMESTAMP DEFAULT
CURRENT\_TIMESTAMP}

);
\end{quote}

